# Copy to `.env` and fill in real values. Never commit the filled version.

# Master key for LiteLLM admin endpoints + worker-to-router auth.
# Generate: openssl rand -hex 32 | sed 's/^/sk-/'
LITELLM_MASTER_KEY=

# Postgres superuser password. Generate: openssl rand -hex 24
POSTGRES_PASSWORD=

# Z.AI API key for the glm/* routes (https://api.z.ai/). Leave empty to disable.
ZAI_API_KEY=
